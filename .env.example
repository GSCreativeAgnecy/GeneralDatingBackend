# ── App ──
APP_NAME=Ardhang Matrimony
API_V1_PREFIX=/api/v1
DEBUG=false

# ── Database (PostgreSQL 16 via asyncpg) ──
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ardhang
DATABASE_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ── JWT Authentication ──
# IMPORANT: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OTP ──
# OTP_BYPASS: Set only in development to bypass OTP check (any value works)
OTP_BYPASS=
OTP_LENGTH=6
OTP_EXPIRE_SECONDS=300
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW_MINUTES=10

# ── OTP Provider (twilio or android_sms_gateway) ──
PREFERRED_OTP_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
ANDROID_SMS_GATEWAY_URL=
ANDROID_SMS_GATEWAY_API_KEY=

# ── File Uploads ──
UPLOAD_DIR=data/uploads
MAX_PHOTO_SIZE_MB=10
MAX_PHOTOS_PER_USER=6

# ── Swipe Limits ──
DAILY_LIKES_FREE=50
DAILY_SUPER_LIKES_FREE=1

# ── Family Share ──
FAMILY_SHARE_EXPIRE_DAYS=7
FAMILY_SHARE_TOKEN_LENGTH=32

# ── SMTP ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Ardhang Matrimony
NOTIFY_EMAIL=

# ── Payment Processors ──
ACTIVE_PAYMENT_PROCESSORS=
DEFAULT_CURRENCY=INR

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# Helcim
HELCIM_API_TOKEN=
HELCIM_ACCOUNT_ID=
HELCIM_WEBHOOK_SECRET=
HELCIM_MODE=sandbox

# ── Admin ──
# Comma-separated list of phone numbers with admin access
ADMIN_PHONES=

# ── CORS ──
# Comma-separated list of allowed origins (e.g. https://app.ardhang.com,https://admin.ardhang.com)
CORS_ORIGINS=
